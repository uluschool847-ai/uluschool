generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Enquiry {
  id                 String   @id @default(cuid())
  studentName        String
  ageYearLevel       String
  subjects           String[]
  curriculumLevelId  String
  curriculumLevel    Level    @relation(fields: [curriculumLevelId], references: [id], onDelete: Restrict)
  parentGuardianName String
  email              String
  phoneWhatsapp      String
  preferredSchedule  String
  additionalNotes    String?
  status             String   @default("NEW")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, createdAt])
  @@index([curriculumLevelId])
}

model Teacher {
  id              String           @id @default(cuid())
  fullName        String
  title           String
  bio             String
  yearsExperience Int?
  isVetted        Boolean          @default(true)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  teacherSubjects TeacherSubject[]
  testimonials    Testimonial[]
}

model Testimonial {
  id            String   @id @default(cuid())
  studentName   String
  guardianName  String?
  quote         String
  levelLabel    String
  teacherId     String?
  teacher       Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  isPublished   Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isPublished, displayOrder])
}

model Subject {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  description     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  levelSubjects   LevelSubject[]
  teacherSubjects TeacherSubject[]
}

model Level {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  description   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  enquiries     Enquiry[]
  levelSubjects LevelSubject[]
}

model LevelSubject {
  levelId   String
  subjectId String
  level     Level   @relation(fields: [levelId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([levelId, subjectId])
}

model TeacherSubject {
  teacherId String
  subjectId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([teacherId, subjectId])
}
